# ReadMeForge — Environment Variables
# Copy this file to .env.local and fill in values before running locally.

# ──────────────────────────────────────────────
# App
# ──────────────────────────────────────────────

# Public URL used for redirect URLs (e.g. Paddle checkout return)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ──────────────────────────────────────────────
# Supabase
# ──────────────────────────────────────────────

# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-side only — never expose to browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ──────────────────────────────────────────────
# Paddle
# ──────────────────────────────────────────────

# Found in: Paddle Dashboard → Developer Tools → Authentication
PADDLE_API_KEY=your-paddle-api-key

# Found in: Paddle Dashboard → Catalog → Prices
PADDLE_PRO_PRICE_ID=pri_xxxxxxxxxxxxxxxx

# Found in: Paddle Dashboard → Developer Tools → Notifications → Webhook secret
PADDLE_WEBHOOK_SECRET=your-webhook-secret

# Found in: Paddle Dashboard → Settings → General → Vendor ID
PADDLE_VENDOR_ID=your-vendor-id

# ──────────────────────────────────────────────
# GitHub (optional — increases API rate limit 60→5000 req/hr)
# ──────────────────────────────────────────────

# Create at: https://github.com/settings/tokens (no scopes needed for public repos)
GITHUB_TOKEN=ghp_your_token_here
